{
  "schema_version": 1,
  "default_release_repo": "bangonkali/baidu-unlimited-ocr-portable",
  "asset_prefix": "uocr-runtime",
  "aggregate_manifest": "uocr-runtime-manifest.json",
  "targets": {
    "macos-arm64-metal": {
      "label": "macOS Apple Silicon / Metal",
      "os": "macos",
      "arch": "arm64",
      "backend": "metal",
      "support_status": "supported",
      "runner": "macos-15",
      "archive_ext": "tar.gz",
      "cmake_defines": [
        "GGML_METAL=ON",
        "GGML_NATIVE=OFF",
        "LLAMA_OPENSSL=OFF",
        "CMAKE_BUILD_RPATH=@loader_path"
      ],
      "executables": [
        "llama-uocr-parity",
        "llama-mtmd-cli",
        "llama-server",
        "trapo-tesseract-rs-runner"
      ],
      "primary_binary": "llama-uocr-parity",
      "required_libraries": [
        "libuocr-ffi.dylib",
        "libtrapo-ocr-ffi.dylib"
      ],
      "library_globs": [
        "*.dylib"
      ],
      "bundled_notice_files": [
        "onnxruntime-LICENSE",
        "onnxruntime-ThirdPartyNotices.txt"
      ],
      "engine_asset_dirs": [
        "ppocrv6",
        "paddleocr_vl_1_6",
        "tesseract"
      ],
      "notes": "Prebuilt runtime for Apple Silicon Macs using the Metal backend."
    },
    "linux-x86_64-cuda13": {
      "label": "Linux x86_64 / CUDA 13",
      "os": "linux",
      "arch": "x86_64",
      "backend": "cuda",
      "cuda_major": 13,
      "support_status": "supported",
      "runner": "ubuntu-24.04",
      "archive_ext": "tar.gz",
      "cmake_defines": [
        "GGML_CUDA=ON",
        "GGML_NATIVE=OFF",
        "LLAMA_OPENSSL=OFF",
        "CMAKE_CUDA_ARCHITECTURES=75-virtual;80-virtual;86-real;89-real;90-virtual;120a-real;121a-real"
      ],
      "cuda_architectures": [
        "75-virtual",
        "80-virtual",
        "86-real",
        "89-real",
        "90-virtual",
        "120a-real",
        "121a-real"
      ],
      "minimum_compute_capability": "7.5",
      "known_gpu_support": [
        {
          "name": "GeForce RTX 5090",
          "compute_capability": "12.0",
          "cmake_architecture": "120a-real"
        }
      ],
      "executables": [
        "llama-uocr-parity",
        "llama-mtmd-cli",
        "llama-server",
        "trapo-tesseract-rs-runner"
      ],
      "primary_binary": "llama-uocr-parity",
      "required_libraries": [
        "libuocr-ffi.so",
        "libtrapo-ocr-ffi.so"
      ],
      "bundled_dependency_libraries": [
        "libcudart.so.13",
        "libcublas.so.13",
        "libcublasLt.so.13",
        "libcufft.so.12",
        "libcurand.so.10",
        "libnvJitLink.so.13",
        "libnvrtc.so.13",
        "libnvrtc-builtins.so.13",
        "libcudnn.so.9"
      ],
      "library_globs": [
        "*.so",
        "*.so.*"
      ],
      "bundled_notice_files": [
        "onnxruntime-LICENSE",
        "onnxruntime-ThirdPartyNotices.txt",
        "NVIDIA-CUDA-EULA.txt",
        "NVIDIA-cuDNN-LICENSE.txt"
      ],
      "engine_asset_dirs": [
        "ppocrv6",
        "paddleocr_vl_1_6",
        "tesseract"
      ],
      "accelerator_probe": "nvidia-smi",
      "notes": "Prebuilt runtime for Linux x86_64 machines. CUDA 13 and cuDNN 9 runtime redistributables are bundled; a compatible host NVIDIA driver is still required."
    },
    "linux-x86_64-rocm6": {
      "label": "Linux x86_64 / AMD ROCm",
      "os": "linux",
      "arch": "x86_64",
      "backend": "rocm",
      "support_status": "planned",
      "runner": "ubuntu-24.04",
      "archive_ext": "tar.gz",
      "cmake_defines": [
        "GGML_HIP=ON",
        "GGML_NATIVE=OFF",
        "LLAMA_OPENSSL=OFF"
      ],
      "executables": [
        "llama-uocr-parity",
        "llama-mtmd-cli",
        "llama-server",
        "trapo-tesseract-rs-runner"
      ],
      "primary_binary": "llama-uocr-parity",
      "required_libraries": [
        "libuocr-ffi.so",
        "libtrapo-ocr-ffi.so"
      ],
      "library_globs": [
        "*.so",
        "*.so.*"
      ],
      "engine_asset_dirs": [
        "ppocrv6",
        "tesseract"
      ],
      "accelerator_probe": "rocminfo",
      "notes": "Best-effort runtime label for AMD ROCm/HIP builds. Validate on AMD hardware before publishing as supported."
    },
    "linux-x86_64-cpu": {
      "label": "Linux x86_64 / CPU",
      "os": "linux",
      "arch": "x86_64",
      "backend": "cpu",
      "support_status": "supported",
      "runner": "ubuntu-24.04",
      "archive_ext": "tar.gz",
      "cmake_defines": [
        "GGML_NATIVE=OFF",
        "LLAMA_OPENSSL=OFF"
      ],
      "executables": [
        "llama-uocr-parity",
        "llama-mtmd-cli",
        "llama-server",
        "trapo-tesseract-rs-runner"
      ],
      "primary_binary": "llama-uocr-parity",
      "required_libraries": [
        "libuocr-ffi.so",
        "libtrapo-ocr-ffi.so"
      ],
      "library_globs": [
        "*.so",
        "*.so.*"
      ],
      "bundled_notice_files": [
        "onnxruntime-LICENSE",
        "onnxruntime-ThirdPartyNotices.txt"
      ],
      "engine_asset_dirs": [
        "ppocrv6",
        "paddleocr_vl_1_6",
        "tesseract"
      ],
      "notes": "CPU-only fallback runtime for machines with enough RAM and no supported GPU."
    },
    "linux-arm64-cpu": {
      "label": "Linux arm64 / CPU",
      "os": "linux",
      "arch": "arm64",
      "backend": "cpu",
      "support_status": "supported",
      "runner": "ubuntu-24.04-arm",
      "archive_ext": "tar.gz",
      "cmake_defines": [
        "GGML_NATIVE=OFF",
        "LLAMA_OPENSSL=OFF"
      ],
      "executables": [
        "llama-uocr-parity",
        "llama-mtmd-cli",
        "llama-server",
        "trapo-tesseract-rs-runner"
      ],
      "primary_binary": "llama-uocr-parity",
      "required_libraries": [
        "libuocr-ffi.so",
        "libtrapo-ocr-ffi.so"
      ],
      "library_globs": [
        "*.so",
        "*.so.*"
      ],
      "bundled_notice_files": [
        "onnxruntime-LICENSE",
        "onnxruntime-ThirdPartyNotices.txt"
      ],
      "engine_asset_dirs": [
        "ppocrv6",
        "paddleocr_vl_1_6",
        "tesseract"
      ],
      "notes": "CPU-only runtime for Ubuntu 24.04 arm64 hosted runners and ARM Linux machines."
    },
    "windows-x86_64-cuda13": {
      "label": "Windows x86_64 / CUDA 13",
      "os": "windows",
      "arch": "x86_64",
      "backend": "cuda",
      "cuda_major": 13,
      "support_status": "supported",
      "runner": "windows-2025",
      "archive_ext": "zip",
      "cmake_defines": [
        "GGML_CUDA=ON",
        "GGML_NATIVE=OFF",
        "LLAMA_OPENSSL=OFF",
        "CMAKE_CUDA_ARCHITECTURES=75-virtual;80-virtual;86-real;89-real;90-virtual;120a-real;121a-real"

{
  "name": "uocr-client",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "build": "bun run generate-api && bun run generate-routes && tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "storybook": "storybook dev -p 6007 --host 127.0.0.1",
    "build-storybook": "storybook build",
    "generate-api": "orval --config orval.config.ts",
    "generate-routes": "tsr generate",
    "test": "bun test",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome check --error-on-warnings .",
    "lint:fix": "biome check --write --unsafe .",
    "typecheck": "bun run generate-api && bun run generate-routes && tsc -b --pretty false"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "1.3.4",
    "@radix-ui/react-dropdown-menu": "^2.1.19",
    "@radix-ui/react-tooltip": "1.2.9",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "^1.170.15",
    "@tanstack/react-store": "^0.11.0",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "^3.14.2",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-joyride": "3.1.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^3.0.6",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@storybook/addon-a11y": "^10.4.5",
    "@storybook/addon-docs": "^10.4.5",
    "@storybook/react-vite": "^10.4.5",
    "@tanstack/router-cli": "^1.167.17",
    "@tanstack/router-plugin": "^1.168.18",
    "@types/node": "^26.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.2",
    "orval": "^8.16.0",
    "storybook": "^10.4.5",
    "typescript": "^5.7.2",
    "vite": "^8.0.16"
  }
}

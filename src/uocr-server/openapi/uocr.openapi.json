{
  "openapi": "3.0.3",
  "info": {
    "title": "Unlimited-OCR Workbench API",
    "version": "0.1.0",
    "description": "Local-first API for the C++ Drogon Unlimited-OCR workbench."
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8765",
      "description": "Portable local server"
    }
  ],
  "paths": {
    "/api/health": {
      "get": {
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "Server health",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/status": {
      "get": {
        "operationId": "getStatus",
        "responses": {
          "200": {
            "description": "Workbench status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/StatusPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/openapi.json": {
      "get": {
        "operationId": "getOpenapi",
        "responses": {
          "200": {
            "description": "Checked-in API description",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    },
    "/api/system/folder-dialog": {
      "post": {
        "operationId": "openFolderDialog",
        "responses": {
          "200": {
            "description": "Native folder dialog result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FolderDialogResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/ingest/start": {
      "post": {
        "operationId": "startIngest",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IngestStartRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Ingest run queued",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestRunRecord"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/api/ingest/runs": {
      "get": {
        "operationId": "listIngestRuns",
        "responses": {
          "200": {
            "description": "Ingest runs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestRunsPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/ingest/metrics/recent": {
      "get": {
        "operationId": "getRecentOcrMetrics",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 50
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent OCR performance metrics",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OcrMetricsTreePayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/ingest/runs/{run_id}": {
      "get": {
        "operationId": "getIngestRun",
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          }
        ],
        "responses": {
          "200": {
            "description": "Ingest run",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestRunRecord"
                }
              }
            }
          }
        }
      }
    },
    "/api/ingest/runs/{run_id}/metrics": {
      "get": {
        "operationId": "getIngestRunMetrics",
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          }
        ],
        "responses": {
          "200": {
            "description": "OCR performance metrics for one ingest run",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OcrMetricsTreePayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/ingest/runs/{run_id}/stop": {
      "post": {
        "operationId": "stopIngestRun",
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          }
        ],
        "responses": {
          "202": {
            "description": "Stop requested",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestRunRecord"
                }
              }
            }
          }
        }
      }
    },
    "/api/ingest/runs/{run_id}/events": {
      "get": {
        "operationId": "streamIngestRunEvents",
        "parameters": [
          {
            "$ref": "#/components/parameters/RunId"
          }
        ],
        "responses": {
          "200": {
            "description": "Server-sent run snapshots",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/documents": {
      "get": {
        "operationId": "listDocuments",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Documents",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentsPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/search": {
      "get": {
        "operationId": "searchDocuments",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "DuckDB-backed document text search",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentsPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/documents/{file_hash}": {
      "get": {
        "operationId": "getDocument",
        "parameters": [
          {
            "$ref": "#/components/parameters/FileHash"
          }
        ],
        "responses": {
          "200": {
            "description": "Document detail",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentDetail"
                }
              }
            }
          }
        }
      }
    },
    "/api/documents/{file_hash}/regions": {
      "get": {
        "operationId": "getDocumentRegions",
        "parameters": [
          {
            "$ref": "#/components/parameters/FileHash"
          }
        ],
        "responses": {
          "200": {
            "description": "Document overlay boxes",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentRegionsPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/documents/{file_hash}/text": {
      "get": {
        "operationId": "getDocumentText",
        "parameters": [
          {
            "$ref": "#/components/parameters/FileHash"
          }
        ],
        "responses": {
          "200": {
            "description": "Cleaned OCR text with region spans",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/DocumentTextPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/documents/{file_hash}/preview-images": {
      "get": {
        "operationId": "getDocumentPreviewImages",
        "parameters": [
          {
            "$ref": "#/components/parameters/FileHash"
          }
        ],
        "responses": {
          "200": {
            "description": "Available preview variants and pages",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PreviewImagesPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/documents/{file_hash}/preview-images/{variant}/{page_no}": {
      "get": {
        "operationId": "getDocumentPreviewImage",
        "parameters": [
          {
            "$ref": "#/components/parameters/FileHash"
          },
          {
            "name": "variant",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "source"
              ]
            }
          },
          {
            "name": "page_no",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "minimum": 1
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Preview image bytes",
            "content": {
              "image/png": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              },
              "image/jpeg": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/ErrorResponse"
          }
        }
      }
    },
    "/api/settings": {
      "get": {
        "operationId": "getSettings",
        "responses": {
          "200": {
            "description": "Runtime settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SettingsPayload"
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateSettings",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SettingsUpdateRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated runtime settings",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SettingsPayload"
                }
              }
            }
          },
          "400": {
            "description": "Unsupported setting",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/models": {
      "get": {
        "operationId": "listModels",
        "responses": {
          "200": {
            "description": "Model assets and OCR profiles",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelsPayload"
                }
              }
            }
          }
        }
      }
    },
    "/api/models/{model_id}/download": {
      "post": {
        "operationId": "downloadModel",
        "parameters": [
          {
            "name": "model_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ModelDownloadRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Download started or already complete",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelDownloadRecord"
                }
              }
            }
          }
        }
      }
    },
    "/api/models/{model_id}/select": {
      "post": {
        "operationId": "selectModel",
        "parameters": [
          {
            "name": "model_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Model selected for subsequent ingest runs",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelSelectRecord"
                }
              }
            }
          }
        }
      }
    },
    "/api/models/{model_id}/cancel": {
      "post": {
        "operationId": "cancelModelDownload",
        "parameters": [
          {
            "name": "model_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "202": {
            "description": "Download cancellation requested",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ModelDownloadRecord"
                }
              }
            }
          }
        }
      }
    },
    "/api/models/{model_id}/events": {
      "get": {
        "operationId": "streamModelDownloadEvents",
        "parameters": [
          {
            "name": "model_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Server-sent model download progress events",
            "content": {
              "text/event-stream": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/api/logs/recent": {
      "get": {
        "operationId": "getRecentLogs",
        "parameters": [
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000,
              "default": 200
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Recent server log lines",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LogsPayload"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "RunId": {
        "name": "run_id",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      },
      "FileHash": {
        "name": "file_hash",
        "in": "path",
        "required": true,
        "schema": {
          "type": "string"
        }
      }
    },
    "responses": {
      "ErrorResponse": {
        "description": "Error payload",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ErrorPayload"
            }
          }
        }
      }
    },
    "schemas": {
      "HealthPayload": {
        "type": "object",
        "required": [
          "ok",
          "service"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          },
          "service": {
            "type": "string"
          }
        }
      },
      "StatusPayload": {
        "type": "object",
        "required": [
          "state",
          "default_profile",
          "supported_inputs"
        ],
        "properties": {
          "state": {
            "type": "string",
            "enum": [
              "idle",
              "queued",
              "running",
              "cancelled",
              "failed",
              "completed",
              "completed_with_errors"
            ]
          },
          "active_run_id": {
            "type": "string",
            "nullable": true
          },
          "host": {
            "type": "string"
          },
          "runtime_platform": {
            "type": "string"
          },
          "accelerator": {
            "type": "string",
            "enum": [
              "cuda",
              "rocm",
              "metal",
              "cpu"
            ]
          },
          "runtime_selectable": {
            "type": "boolean"
          },
          "inference_engine": {
            "type": "string"
          },
          "log_path": {
            "type": "string"
          },
          "database_path": {
            "type": "string"
          },
          "realtime_path": {
            "type": "string"
          },
          "default_profile": {
            "type": "string"
          },
          "selected_model_id": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "git_tag": {
            "type": "string"
          },
          "git_sha": {
            "type": "string"
          },
          "supported_inputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "runtime_variants": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/RuntimeVariantRecord"
            }
          }
        }
      },
      "FolderDialogResponse": {
        "type": "object",
        "required": [
          "cancelled",
          "selected_path",
          "manual_path_supported"
        ],
        "properties": {
          "cancelled": {
            "type": "boolean"
          },
          "selected_path": {
            "type": "string"
          },
          "manual_path_supported": {
            "type": "boolean"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "IngestStartRequest": {
        "type": "object",
        "required": [
          "root_path"
        ],
        "properties": {
          "root_path": {
            "type": "string"
          },
          "profile_id": {
            "type": "string"
          },
          "model_id": {
            "type": "string"
          },
          "reprocess": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "IngestRunRecord": {
        "type": "object",
        "required": [
          "run_id",
          "root_path",
          "status"
        ],
        "properties": {
          "run_id": {
            "type": "string"
          },
          "root_path": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "queued_files": {
            "type": "integer"
          },
          "processed_pages": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          },
          "current_page": {
            "type": "integer"
          },
          "progress_percent": {
            "type": "number",
            "format": "double"
          },
          "profile_id": {
            "type": "string"
          },
          "engine_id": {
            "type": "string"
          },
          "model_id": {
            "type": "string"
          },
          "runtime_id": {
            "type": "string"
          },
          "error": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "IngestRunsPayload": {
        "type": "object",
        "required": [
          "runs"
        ],
        "properties": {
          "runs": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IngestRunRecord"
            }
          }
        }
      },
      "OcrMetricsTreeNode": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "label",
          "run_id",
          "status",
          "token_count",
          "chunk_count",
          "page_count",
          "first_token_latency_ms",
          "generation_duration_ms",
          "elapsed_ms",
          "min_tps",
          "max_tps",
          "avg_tps"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "run",
              "file",
              "page"
            ]
          },
          "label": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "file_hash": {
            "type": "string"
          },
          "page_no": {
            "type": "integer"
          },
          "status": {
            "type": "string"
          },
          "model_id": {
            "type": "string"
          },
          "runtime_id": {
            "type": "string"
          },
          "runtime_platform": {
            "type": "string"
          },
          "accelerator": {
            "type": "string"
          },
          "token_count": {
            "type": "integer"
          },
          "chunk_count": {
            "type": "integer"
          },
          "page_count": {
            "type": "integer"
          },
          "first_token_latency_ms": {
            "type": "integer"
          },
          "generation_duration_ms": {
            "type": "integer"
          },
          "elapsed_ms": {
            "type": "integer"
          },
          "min_tps": {
            "type": "number",
            "format": "double"
          },
          "max_tps": {
            "type": "number",
            "format": "double"
          },
          "avg_tps": {
            "type": "number",
            "format": "double"
          },
          "started_at": {
            "type": "string"
          },
          "completed_at": {
            "type": "string"
          },
          "error": {
            "type": "string",
            "nullable": true
          },
          "children": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OcrMetricsTreeNode"
            }
          }
        }
      },
      "OcrMetricsTreePayload": {
        "type": "object",
        "required": [
          "nodes"
        ],
        "properties": {
          "nodes": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/OcrMetricsTreeNode"
            }
          }
        }
      },
      "DocumentSummary": {
        "type": "object",
        "required": [
          "file_hash",
          "display_name",
          "status",
          "page_count"
        ],
        "properties": {
          "file_hash": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "relative_path": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "page_count": {
            "type": "integer"
          },
          "processed_pages": {
            "type": "integer"
          },
          "total_pages": {
            "type": "integer"
          },
          "current_page": {
            "type": "integer"
          },
          "progress_percent": {
            "type": "number",
            "format": "double"
          },
          "regions": {
            "type": "integer"
          },
          "error": {
            "type": "string"
          }
        }
      },
      "DocumentsPayload": {
        "type": "object",
        "required": [
          "documents"
        ],
        "properties": {
          "documents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DocumentSummary"
            }
          }
        }
      },
      "DocumentDetail": {
        "allOf": [
          {
            "$ref": "#/components/schemas/DocumentSummary"
          },
          {
            "type": "object",
            "properties": {
              "absolute_path": {
                "type": "string"
              }
            }
          }
        ]
      },
      "OverlayBox": {
        "type": "object",
        "required": [
          "region_id",
          "label",
          "page_no",
          "left_percent",
          "top_percent",
          "width_percent",
          "height_percent"
        ],
        "properties": {
          "region_id": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "content_markdown": {
            "type": "string"
          },
          "content_html": {
            "type": "string",
            "nullable": true
          },
          "page_no": {
            "type": "integer"
          },
          "left_percent": {
            "type": "number"
          },
          "top_percent": {
            "type": "number"
